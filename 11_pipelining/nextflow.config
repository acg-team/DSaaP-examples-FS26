params {
    input = 'data/*.fasta'
    outdir = 'results'
}

manifest {
    name = 'PKS Analysis Pipeline'
    description = 'Pipeline for polyketide synthase analysis: FASTA → Alignment → Phylogenetic Analysis (raxml-ng and BEAST2)'
    version = '1.0.0'
    nextflowVersion = '>=25'
}

// ---------------------------------------------------------------------------
// Reports
// ---------------------------------------------------------------------------
timeline {
    enabled = true
    file = "${projectDir}/results/pipeline_info/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file = "${projectDir}/results/pipeline_info/report.html"
    overwrite = true
}
trace {
    enabled = true
    file = "${projectDir}/results/pipeline_info/trace.txt"
    overwrite = true
}
dag {
    enabled = true
    file = "${projectDir}/results/pipeline_info/dag.html"
    overwrite = true
}

// ---------------------------------------------------------------------------
// Runner configuration
// ---------------------------------------------------------------------------
profiles {

    // Run locally with micromamba environment
    standard {
        process.executor = 'local'
        process.conda = '/path/to/mamba/envs/polyketide_analysis'
        conda.enabled = true
        conda.useMicromamba = true
    }

    // Run on a SLURM cluster with a conda environment
    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'
        process.clusterOptions = '--account=<your_account>'
        process.conda = '/path/to/conda/envs/polyketide_analysis'
        conda.enabled = true
        conda.useMicromamba = false
    }

    // Run on a SLURM cluster with a shared conda environment
    slurm_zhaw {
        process.executor = 'slurm'
        process.queue = 'earth-1'
        process.time = '24:00:00'
        process.memory = '32.GB'
        process.conda = '/path/to/conda/envs/polyketide_analysis'
        conda.enabled = true
        conda.useMicromamba = false
        process.shell = ['/bin/bash', '-lc']
        process.beforeScript = '''
        module purge
        module load DefaultModules
        module load USS/2022
        module load gcc/9.4.0-pe5.34 miniconda3/4.12.0 lsfm-init-miniconda/1.0.0
        module load jdk/19
        '''
    }
}
